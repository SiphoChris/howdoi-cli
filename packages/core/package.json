{
  "name": "@howdoi-cli/core",
  "version": "1.0.0",
  "description": "The howdoi CLI engine — intent-based command discovery for the terminal.",
  "type": "module",
  "bin": {
    "howdoi": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "publish:npm": "npm publish"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "fuse.js": "^7.0.0",
    "js-yaml": "^4.1.0"
  },
  "keywords": [
    "cli", "unix", "terminal", "git", "commands", "developer-tools", "howdoi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SiphoChris/howdoi-cli"
  },
  "homepage": "https://github.com/SiphoChris/howdoi-cli#readme",
  "bugs": {
    "url": "https://github.com/SiphoChris/howdoi-cli/issues"
  }
}
